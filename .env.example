# ResearchBuddy Environment Variables

# AI API Configuration (required for AI review feature)
# Get your key from: https://platform.openai.com/  or https://openrouter.ai/
NEXT_PUBLIC_AI_API_KEY=your_api_key_here
NEXT_PUBLIC_AI_API_URL=https://api.openai.com/v1/chat/completions
NEXT_PUBLIC_AI_MODEL=gpt-4o-mini

# Alternative: use OpenRouter for Claude/GPT access
# NEXT_PUBLIC_AI_API_URL=https://openrouter.ai/api/v1/chat/completions
# NEXT_PUBLIC_AI_MODEL=anthropic/claude-3-5-haiku-20241022
